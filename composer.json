{
    "name": "aubes/correlation-core",
    "type": "symfony-bundle",
    "description": "Core bundle for correlation ID management: storage, generator and shared contracts",
    "keywords": ["symfony", "bundle", "correlation-id", "tracing", "observability"],
    "license": "MIT",
    "homepage": "https://github.com/aubes/correlation-core",
    "support": {
        "issues": "https://github.com/aubes/correlation-core/issues",
        "source": "https://github.com/aubes/correlation-core"
    },
    "authors": [
        {
            "name": "Aurélian Bes"
        }
    ],
    "require": {
        "php": "^8.2",
        "symfony/console": "^6.4 | ^7.4 | ^8.0",
        "symfony/http-kernel": "^6.4 | ^7.4 | ^8.0",
        "symfony/service-contracts": "^3.0",
        "symfony/uid": "^6.4 | ^7.4 | ^8.0",
        "symfony/dependency-injection": "^6.4 | ^7.4 | ^8.0",
        "symfony/config": "^6.4 | ^7.4 | ^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.1",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0 | ^12.0"
    },
    "autoload": {
        "psr-4": { "Aubes\\CorrelationCore\\": "src" },
        "exclude-from-classmap": [
            "/tests"
        ]
    },
    "autoload-dev": {
        "psr-4": { "Aubes\\CorrelationCore\\Tests\\": "tests" }
    },
    "scripts": {
        "analyse": [
            "@cs",
            "@phpstan",
            "@composer audit"
        ],
        "cs": "php-cs-fixer fix --allow-risky=yes --config=.php-cs-fixer.php --dry-run --verbose",
        "fix-cs": "php-cs-fixer fix --allow-risky=yes --config=.php-cs-fixer.php --show-progress=dots --verbose",
        "phpstan": "phpstan analyse",
        "test": "phpunit tests",
        "coverage": "phpunit tests --coverage-html coverage/ --coverage-clover coverage/clover.xml"
    }
}
